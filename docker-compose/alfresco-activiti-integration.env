# Alfresco-Activiti Integration Configuration

# Alfresco side configuration
ALFRESCO_ACTIVITI_URL=http://activiti-nginx/rb
ALFRESCO_ACTIVITI_ENABLED=true
ALFRESCO_ACTIVITI_USER=admin
ALFRESCO_ACTIVITI_PASSWORD=admin

# Activiti side configuration
ACTIVITI_ALFRESCO_URL=http://docker-compose-alfresco-1:8080/alfresco
ACTIVITI_ALFRESCO_USER=admin
ACTIVITI_ALFRESCO_PASSWORD=admin
ACTIVITI_ALFRESCO_ENABLED=true

# Shared Message Broker Configuration (if using same broker)
ALFRESCO_BROKER_URL=nio://docker-compose-activemq-1:61616
ACTIVITI_BROKER_URL=amqp://activiti-rabbitmq:5672